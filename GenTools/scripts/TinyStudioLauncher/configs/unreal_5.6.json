{
  "name": "Unreal Engine 5.6",
  "repository": "UnrealRepository",
  "python_version": "3.10",
  "executable_type": "project",
  "project_pattern": "{SAGA_BASE_SHOW_DIR}{SHOW_NAME}/unreal/{version}/Project.uproject",
  "icon": "unreal.png",
  "additional_paths": ["{UNREAL_REPO}/scripts", "{UNREAL_REPO}/tools"],
  "env_vars": {
    "UE_PROJECT_DIR": "{SAGA_BASE_SHOW_DIR}{SHOW_NAME}/unreal/{version}",
    "UE_ENGINE_DIR": "C:/Program Files/Epic Games/UE_{version}",
    "UE_PYTHON_DIR": "{UNREAL_REPO}/python"
  },
  "script_paths": ["scripts", "tools"],
  "supported_shows": "all"
}
