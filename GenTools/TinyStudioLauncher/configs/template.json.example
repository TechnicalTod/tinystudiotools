{
  "name": "Application Name",
  "repository": "AppRepository",
  "python_version": "3.10",
  "executable_path": "C:/Program Files/AppName/app.exe",
  "icon": "app.png",
  "additional_paths": [
    "{APP_REPO}/scripts",
    "{APP_REPO}/plugins"
  ],
  "env_vars": {
    "APP_PATH": "{APP_REPO}",
    "APP_PROJECT": "{TINYSTUDIO_BASE_SHOW_DIR}{SHOW_NAME}/app",
    "APP_REPO": "{SCRIPT_DIR}AppRepository"
  },
  "script_paths": ["scripts", "shared", "tools"],
  "startup_script": "startup.py",
  "supported_shows": "all"
} 