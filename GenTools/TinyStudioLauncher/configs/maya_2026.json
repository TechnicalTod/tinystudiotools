  "qt_plugin_path": "C:/Program Files/Autodesk/Maya{version}/plugins/platforms",
  "icon": "maya.png",
  "additional_paths": [
    "{MAYA_REPO}/scripts/melScripts",
    "{MAYA_REPO}/scripts/Publisher",
